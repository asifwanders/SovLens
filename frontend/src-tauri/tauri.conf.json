{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "SovLens",
  "version": "0.1.6",
  "identifier": "com.sovstac.sovlens",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SovLens",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:14793 http://localhost:14793 http://localhost:3000 ws://localhost:3000 https://github.com https://*.githubusercontent.com; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' blob: data: http://127.0.0.1:14793 http://localhost:14793; media-src 'self' blob: data: http://127.0.0.1:14793 http://localhost:14793; font-src 'self' data:; frame-src 'none'; object-src 'none'; base-uri 'self'; form-action 'self'"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["app", "nsis"],
    "publisher": "SovStac",
    "copyright": "Copyright © SovStac 2026",
    "homepage": "https://sovstac.com",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "binaries/sovlens-backend.tar.gz"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "./windows/hooks.nsh"
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY2RTY1NUNDQkEwOEQ5RgpSV1NmamFETFhHVnVEN216YlA1QzhNTVJzK2UzSEFDR3pVVStuckNuVm01RlZmM0FJY1h5VW0xaQo=",
      "endpoints": [
        "https://github.com/asifwanders/SovLens/releases/latest/download/latest.json"
      ]
    }
  }
}
