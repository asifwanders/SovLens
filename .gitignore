# ─── SovLens runtime data ──────────────────────────────
# LanceDB index, model caches, transcoded media — never commit
# (lancedb_data is legacy; new installs use <app_data>/lancedb which lives
# outside the repo — kept here for older clones that still have it locally.)
backend/lancedb_data/
backend/lancedb/
backend/temp_frames/
backend/.EasyOCR/

